<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF1A1A2E"
    android:padding="16dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="排行榜"
        android:textSize="32sp"
        android:textColor="#FFFFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp" />

    <!-- 难度筛选按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_filter_easy"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="简单"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF4CAF50"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_filter_medium"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="普通"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FFFF9800"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_filter_hard"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="困难"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FFF44336" />
    </LinearLayout>

    <!-- 表头 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#33FFFFFF">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="名次"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="玩家"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="分数"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="时间"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

    <!-- 排行榜列表 -->
    <ListView
        android:id="@+id/lv_ranking"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#33FFFFFF"
        android:dividerHeight="1dp"
        android:choiceMode="singleChoice" />

    <!-- 无数据提示 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="暂无记录"
        android:textSize="18sp"
        android:textColor="#88FFFFFF"
        android:gravity="center"
        android:visibility="gone" />

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btn_delete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="删除选中"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FFF44336"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="返回"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:backgroundTint="#FF607D8B" />
    </LinearLayout>

</LinearLayout>
